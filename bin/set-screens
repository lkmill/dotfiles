#!/bin/sh

if [ -z "$1" ]; then
  hostname=$(hostname)
else
  hostname=$1
fi

case $hostname in
  "bengt")
    xrandr --output DVI-I-1 --primary --auto --output DP-0 --left-of DVI-I-1 --auto --output HDMI-0 --right-of DVI-I-1 --auto
    ;;
  "bosse")
    xrandr --output DVI-I-1 --primary --auto --output DP-0 --left-of DVI-I-1 --auto --output DVI-D-0 --right-of DVI-I-1 --auto
    ;;
  "charlie")
    xrandr --output DVI-I-1 --primary --auto --output DVI-D-0 --left-of DVI-I-1 --auto --output DP-1 --right-of DVI-I-1 --auto
    ;;
  "connor")
    xrandr --output DP-0 --primary --auto --output DP-2 --auto --left-of DP-0 --output HDMI-0 --auto --right-of DP-0
    ;;
  "hans")
    xrandr --output DVI-I-1 --primary --auto --output DVI-D-0 --left-of DVI-I-1 --auto --output HDMI-0 --right-of DVI-I-1 --auto
    ;;
  "leo")
    xrandr --listmonitors | awk 'NF==4 { print "--output " $4 " --off"}' | sed '/eDP1/d' | xargs xrandr --output eDP1 --primary --auto
    ;;
  "leo-friggeboden")
    # xrandr --output DP2-2 --auto --primary --output DP1 --auto --left-of DP2-2 --output eDP1 --off
    xrandr --output DP2-2 --auto --primary --output eDP1 --off
    ;;
  "leo-trast")
    xrandr --output eDP1 --off --output DP2 --auto --primary --output DP1-1 --auto --left-of DP2
    ;;
  "2-12")
    xrandr --output DP2-1 --primary --auto --output DP2-2 --left-of DP2-1 --auto --output eDP1 --off
    ;;
  "2-23")
    xrandr --output DP2-2 --primary --auto --output DP2-3 --left-of DP2-2 --auto --output eDP1 --off
    ;;
  "2-32")
    xrandr --output DP2-3 --primary --auto --output DP2-2 --left-of DP2-3 --auto --output eDP1 --off
    ;;
esac
